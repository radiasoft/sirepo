{
    "dynamicFiles": {
        "sirepoLibs": {
            "js": [
                "jupyterhublogin.js"
            ]
        }
    },
    "appDefaults": {
        "route": "migrateJupyterHub"
    },
    "localRoutes": {
        "migrateJupyterHub": {
            "route": "/migrate-jupyter",
            "config": {
                "controller": "JupyterHubMigrateController as jupyterHubMigrate",
                "templateUrl": "/static/html/jupyter-migrate.html"
            }
        },
        "jupyterHubNameConflict": {
            "route": "/jupyter-name-conflict",
            "config": {
                "controller": "NameConflictController as nameConflict",
                "templateUrl": "/static/html/jupyter-name-conflict.html"
            }
        },
        "userApprovals": {
            "route": "/jupyter-user-approvals",
            "config": {
                "templateUrl": "/static/html/jupyter-user-approvals.html"
            }
        }
    }
}
