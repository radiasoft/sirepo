import numpy
import scipy.interpolate
from pykern.pkcollections import PKDict


def _read_3d_file(filename):
    v = numpy.loadtxt(filename, skiprows=2).reshape((-1, 3))
    h = v[:3]
    return v[3:], PKDict(
        x=f"{h[0][0]} {h[0][1]}",
        nx=int(h[0][2]),
        y=f"{h[1][0]} {h[1][1]}",
        ny=int(h[1][2]),
        z=f"0.0 {h[2][1] - h[2][0]}",
        nz=int(h[2][2]),
    )


def _write_cavity_3d(filename, frequency_mhz):
    v, h = _read_3d_file(filename)
    v = v.reshape((h.nx, h.ny, h.nz, 2, 3))
    v[:, :, :, 0, :] /= 10000  # V/cm to MV/m
    v[:, :, :, 1, :] *= 79.58  # Gauss to A/m
    for i in range(3):
        v = numpy.flip(v, axis=i)
    with open(filename, "w") as f:
        f.write(
            f"3DDynamic FALSE\n{frequency_mhz}\n{h.x} {h.nx - 1}\n{h.y} {h.ny - 1}\n{h.z} {h.nz - 1}\n"
        )
        numpy.savetxt(f, v.reshape((h.nx * h.ny * h.nz, -1)))


def _write_solenoid_1d(filename):
    v, h = _read_3d_file(filename)
    bz = v.reshape((h.nx, h.ny, h.nz, 3))[int(h.nx / 2), int(h.ny / 2), :, 2]
    bz = scipy.interpolate.interp1d(
        numpy.linspace(0, 1, num=len(bz)), bz, kind="cubic"
    )(numpy.linspace(0, 1, num=len(bz) * 2))
    with open(filename, "w") as f:
        f.write(f"1DMagnetoStatic 50\n{h.z} {len(bz) - 1}\n{h.x} {h.nx - 1}\n")
        numpy.savetxt(f, bz)


{% for c in conversions %}
{% if c.type == "EMS" %}
_write_solenoid_1d("{{ c.lib_file }}")
{% else %}
_write_cavity_3d("{{ c.lib_file }}", {{ c.frequency_mhz }})
{% endif %}
{% endfor %}
